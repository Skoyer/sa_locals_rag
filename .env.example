# Copy to .env and fill in your values. .env is gitignored.
# PLAYLIST_URL is required. For Locals.com, also set LOCALS_EMAIL and LOCALS_PASSWORD.

PLAYLIST_URL=https://locals.com/scottadams/feed?playlist=102
LOCALS_EMAIL=your@email.com
LOCALS_PASSWORD=your_password

# Optional (defaults shown)
# OUTPUT_DIR=./downloads
# DB_PATH=./playlist_archive.db

# Transcription (Whisper): see README — large PyTorch + model download on first run
# TRANSCRIPT_DIR=./transcriptions
# WHISPER_MODEL=small

# Help indexer (separate DB + FTS for “help” search site; see README)
# HELP_MEDIA_DIR=./downloads
# HELP_VIDEOS_DB=./help_videos.db
# HELP_WHISPER_MODEL=small
# LOCALS_COOKIES_PATH=./locals_cookies.txt

# Scheduler cadence (minutes). Change this to adjust run frequency.
# RUN_EVERY_MINUTES=5

# Debug: save playlist HTML and API responses; show browser window for video page
# LOCALS_DEBUG_HTML=1
# LOCALS_HEADLESS=0
